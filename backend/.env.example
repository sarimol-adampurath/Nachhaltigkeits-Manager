DJANGO_SECRET_KEY=replace-with-strong-secret
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com

# Comma-separated URLs
# For single-host deployment, set these to your one app domain.
CORS_ALLOWED_ORIGINS=https://your-domain.com
CSRF_TRUSTED_ORIGINS=https://your-domain.com

# Used by forgot/reset password link generation
FRONTEND_URL=https://your-domain.com

# Set to True/False in production depending on your proxy setup
DJANGO_SECURE_SSL_REDIRECT=True
